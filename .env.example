# Anthropic API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Resend API key — get yours at https://resend.com (free tier: 3,000 emails/month)
RESEND_API_KEY=your_resend_key_here

# Optional: default business email if no client config matches
DEFAULT_BUSINESS_EMAIL=you@yourdomain.com
